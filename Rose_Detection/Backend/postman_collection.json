{
	"info": {
		"name": "PlantVillage Rose Disease Detection",
		"description": "Rose disease detection API (single image).\n\nEndpoints:\n- POST /detect_flowers — fetch S3 image and return detections\n- GET /health — health check",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000"
		}
	],
	"item": [
		{
			"name": "Detection",
			"item": [
				{
					"name": "POST - Detect Flowers",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Has detections array', function() {",
									"    var data = pm.response.json();",
									"    pm.expect(data.detections).to.be.an('array');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"image_s3_uri\": \"s3://rose-images/leaf.jpg\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/detect_flowers",
							"host": ["{{base_url}}"],
							"path": ["detect_flowers"]
						},
						"description": "Single-image detection using an S3 URI."
					}
				}
			]
		},
		{
			"name": "Health",
			"item": [
				{
					"name": "GET - Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Server is healthy', function() {",
									"    pm.expect(pm.response.json().status).to.eql('ok');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Verify the server is running and model is loaded."
					}
				}
			]
		}
	]
}
